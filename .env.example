ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# Per-ticket: fetch threads+comments+history in parallel (default on). Set 0 to disable.
ZOHO_PARALLEL_FETCH=1
# Background sync interval (minutes). Higher = fewer Zoho API calls per day. Min 15, max 1440.
ZOHO_SYNC_INTERVAL_MINUTES=30
# Reporting timezone (IANA). Default US Pacific (PST/PDT). Metabase views v_reporting_*_pt use this.
ANALYTICS_REPORT_TIMEZONE=America/Los_Angeles
# Comma-separated agents to hide from analytics (raw rows still stored). Name and/or id.
ANALYTICS_EXCLUDED_AGENT_NAMES=TechProduct Team
ANALYTICS_EXCLUDED_AGENT_IDS=7296000004702077
SYNC_LOOKBACK_DAYS=31
# Overlap with last sync; lower = slightly fewer duplicate ticket fetches (default 24 is safe).
SYNC_OVERLAP_HOURS=24
DATABASE_URL=postgresql://postgres:postgres@db:5432/zoho_analytics

# AI assistant draft-response settings. AI_BASE_URL can point to OpenAI-compatible APIs.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
ASSISTANT_KNOWLEDGE_PATH=knowledge/zoho_support.md
ASSISTANT_KNOWLEDGE_MAX_CHARS=24000
ASSISTANT_MAX_TICKET_MESSAGES=12
ASSISTANT_REMINDER_TIMEZONE=America/Vancouver
# Safety guard: draft only when ticket assignee matches this allowlist. Default is Kasra-only.
ASSISTANT_REQUIRE_ALLOWED_ASSIGNEE=1
ASSISTANT_ALLOWED_ASSIGNEE_NAMES=Kasra

# Telegram reminders. Create a bot with BotFather and put your personal/chat id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REMINDER_INTERVAL_MINUTES=5
# Poll Telegram for commands like /draft and /remind, so you do not run curl manually.
TELEGRAM_BOT_POLLING_ENABLED=1
TELEGRAM_BOT_POLL_INTERVAL_SECONDS=10
